// Method 1
// Time Complexity	O(n²)
// Space Complexity	O(n)
class Solution {
    public int calcNextIndex(int[] nums , int curr){
        int next =curr;

        int seq= nums[curr];
        if(seq>0){
            next = (next+seq) % nums.length;
        }else{
            int mod = seq % nums.length;
            int forward = nums.length + mod;
            next=(curr + forward) % nums.length;
        }
        return next;
    }
    public boolean circularArrayLoop(int[] nums) {
        for(int i = 0; i<nums.length ; i++){
            Set <Integer> set = new HashSet <>();
            set.add(i) ;
            boolean isPositive = nums[i]>0;

            //cycle detection
            int curr = i;
            while(true){
                int next = calcNextIndex(nums , curr);
                if(isPositive){
                    if(nums[next] < 0){
                        break;
                    }else{
                        if(set.contains(next)){
                            if(curr != next){
                                return true;
                            }else break;
                        }
                        set.add(next);
                    }
                }else{
                    if(nums[next] > 0){
                        break;
                    }else{
                        if(set.contains(next)){
                            if(curr != next){
                                return true;
                            }else break;
                        }
                        set.add(next);
                    }
                }
                curr = next;
            }

        }
        return false;
    }
}








