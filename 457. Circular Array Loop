//Method -3
//Time Complexity	O(n)
//Space Complexity	O(1)
class Solution {
    // TC- O(n)    SC- O(1)
    public int calcNextIndex(int[] nums , int curr){
        int next =curr;

        int seq= nums[curr];
        if(seq>0){
            next = (next+seq) % nums.length;
        }else{
            int mod = seq % nums.length;
            int forward = nums.length + mod;
            next=(curr + forward) % nums.length;
        }
        return next;
    }
    public boolean circularArrayLoop(int[] nums) {
        for(int i = 0; i<nums.length ; i++){
            if(nums[i]==0) continue;
            
            boolean isPositive = nums[i]>0;

            //cycle detection
            int slow = i;
            int fast=i;

            do{
                slow = calcNextIndex( nums , slow);
                fast = calcNextIndex( nums , fast);
                if(isPositive){
                    if(nums[fast]<0) break;
                }else{
                    if(nums[fast]>0) break;
                }
                fast = calcNextIndex( nums , fast);
                if(isPositive){
                    if(nums[fast]<0) break;
                }else{
                    if(nums[fast]>0) break;
                }
                if(slow == fast){
                    //cycle
                    if(slow != calcNextIndex( nums , slow)) return true;
                    break;
                }
            }while(slow != fast);
            
            int curr = i;
            if(isPositive){
                while(nums[curr] >0){
                    int next = calcNextIndex( nums , curr);
                    nums[curr] =0;
                    curr =next;
                }
            }else{
                while(nums[curr] < 0){
                    int next = calcNextIndex( nums , curr);
                    nums[curr] =0;
                    curr =next;
                }
            }
        }
        return false;
    }
}
